<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trade Journal</title>
  </head>
  <body>
    <h1>Trade Journal</h1>

    <form action="/trades" method="POST">
      <label for="ticker">Ticker:</label>
      <input id="ticker" name="ticker" type="text" required />

      <label for="type">Type:</label>
      <select id="type" name="type" required>
        <option value="Long">Long</option>
        <option value="Short">Short</option>
      </select>

      <label for="outcome">Outcome:</label>
      <select id="outcome" name="outcome" required>
        <option value="Profit">Profit</option>
        <option value="Loss">Loss</option>
      </select>

      <button type="submit">Add Trade</button>
    </form>

    <h2>All Trades</h2>
    <ul>
      <% trades.forEach((trade) => { %>
      <li>
        <strong><%= trade.ticker %></strong> -
        <%= trade.type %> -
        <%= trade.outcome %>
        <button class="edit-btn" data-id="<%= trade._id %>">Edit</button>
        <button class="delete-btn" data-id="<%= trade._id %>">Delete</button>
      </li>
      <% }); %>
    </ul>

    <script>
      document.querySelectorAll('.delete-btn').forEach((button) => {
        button.addEventListener('click', async () => {
          const id = button.dataset.id;

          const response = await fetch(`/trades/${id}`, {
            method: 'DELETE',
          });

          if (response.ok) {
            window.location.reload();
          }
        });
      });

      document.querySelectorAll('.edit-btn').forEach((button) => {
        button.addEventListener('click', async () => {
          const id = button.dataset.id;
          const newOutcome = prompt('Enter new outcome (Profit or Loss):');
          const newTicker = prompt('Enter new ticker (leave blank to keep current):');

          const updates = {};
          if (newOutcome) updates.outcome = newOutcome;
          if (newTicker) updates.ticker = newTicker;

          if (Object.keys(updates).length === 0) return;

          const response = await fetch(`/trades/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(updates),
          });

          if (response.ok) {
            window.location.reload();
          }
        });
      });
    </script>
  </body>
</html>
